{
  "name": "spherical-projection",
  "version": "1.0.0",
  "description": "A network laid out on a sphere with d3-force-3d, then unfolded onto the plane through a dozen geographic projections — Mercator, Orthographic, Equal Earth — rendered live with PIXI.js.",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production"
  },
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodighiero/spherical-projection.git"
  },
  "author": "Dario Rodighiero",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-force-3d": "^3.0.6",
    "d3-geo-projection": "^4.0.0",
    "normalize.css": "^8.0.1",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.18.1",
    "versor": "^0.2.0"
  }
}
